SERVER_PORT=8080

DATABASE_URL=jdbc:postgresql://localhost:5432/failframe
DATABASE_USERNAME=failframe
DATABASE_PASSWORD=failframe
JPA_DDL_AUTO=validate

FAILFRAME_SECURITY_USERNAME=failframe
FAILFRAME_SECURITY_PASSWORD=failframe
FAILFRAME_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FAILFRAME_MAX_REQUEST_BYTES=131072
MAX_HTTP_REQUEST_HEADER_SIZE=16KB
MAX_SWALLOW_SIZE=256KB
MAX_REQUEST_SIZE=128KB

FAILFRAME_AI_PROVIDER=mock
