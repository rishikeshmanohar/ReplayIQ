# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Seeded by Flyway for local development. Stored in PostgreSQL as a salted SHA-256 hash.
FAILFRAME_LOCAL_API_KEY=failframe-local-dev-key
