SERVER_PORT=8080

DATABASE_URL=jdbc:postgresql://localhost:5432/debugflow
DATABASE_USERNAME=debugflow
DATABASE_PASSWORD=debugflow
JPA_DDL_AUTO=validate

DEBUGFLOW_SECURITY_USERNAME=debugflow
DEBUGFLOW_SECURITY_PASSWORD=debugflow
DEBUGFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUGFLOW_MAX_REQUEST_BYTES=131072
MAX_HTTP_REQUEST_HEADER_SIZE=16KB
MAX_SWALLOW_SIZE=256KB
MAX_REQUEST_SIZE=128KB

DEBUGFLOW_AI_PROVIDER=mock
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Seeded by Flyway for local development. Stored in PostgreSQL as a salted SHA-256 hash.
DEBUGFLOW_LOCAL_API_KEY=debugflow-local-dev-key
